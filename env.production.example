# CoreSync - Production Environment Template (Foundry Agent Service)
# =============================================================================
# This template documents the environment variables injected by the
# Azure AI Foundry Agent Service Hosted Agent runtime when CoreSync
# runs as a containerized, production-grade autonomous agent.
#
# KEYLESS ARCHITECTURE NOTICE:
# Unlike env.example (used for local development with AZURE_OPENAI_API_KEY),
# this configuration uses NO API KEYS of any kind. Authentication is handled
# entirely by a Microsoft Entra ID Managed Identity assigned to the Hosted
# Agent, with explicit RBAC role assignments:
#
#   - "Cognitive Services OpenAI User" on the Azure OpenAI resource
#   - Read access to the Foundry IQ Knowledge Base / indexed audit policies
#
# NEVER store this file with real values in version control.
# =============================================================================

# --------------------------------------------------
# Azure AI Foundry Project (Managed Identity auth)
# --------------------------------------------------

# Endpoint of the Azure AI Foundry project hosting the deployed model.
# Authentication is performed via the container's assigned Managed Identity -
# no key is read from this file or from any environment variable.
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com

# Name of the deployed reasoning model (e.g. gpt-4o)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# --------------------------------------------------
# CoreSync Inference Engine Configuration
# --------------------------------------------------

# Controls which Foundry IQ rule fixture set is loaded by FoundryIQConnector
EXECUTION_ENVIRONMENT=dev

# Path to the input dataset inside the container filesystem
INGESTION_DATA_PATH=/app/data/synthetic_records.json

# --------------------------------------------------
# Hosted Agent State Persistence
# --------------------------------------------------

# Mount path for the Hosted Agent runtime's native state persistence volume.
# Used to resume long-running batch reconciliation jobs without losing the
# in-memory analytical report trace if the container restarts.
STATE_PERSISTENCE_PATH=/app/state
