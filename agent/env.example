# CoreSync - Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --------------------------------------------------
# Azure OpenAI
# --------------------------------------------------

# Full endpoint URL from Azure Portal > Your OpenAI Resource > Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/

# API key from Azure Portal > Your OpenAI Resource > Keys and Endpoint
AZURE_OPENAI_API_KEY=<your-api-key>

# API version - check Azure OpenAI docs for the latest stable release
AZURE_OPENAI_API_VERSION=2024-02-01

# Name of your deployed model inside Azure OpenAI Studio (e.g. gpt-4o)
DEPLOYMENT_NAME=<your-deployment-name>
